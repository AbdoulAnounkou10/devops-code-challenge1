# Build stage
FROM node:16 as build

WORKDIR /app
COPY package*.json ./
RUN npm install

COPY . .
# Build the React app
RUN npm run build

# Production stage
FROM nginx:alpine
# Copy build output to Nginx
COPY --from=build /app/build /usr/share/nginx/html
# Expose port 80 for the frontend
EXPOSE 80
# Start Nginx
CMD ["nginx", "-g", "daemon off;"]